NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password123
INDEX_NAME=vector
TIMEOUT=5000

# --- Community detection scope ---
# `full`     : run Louvain/Leiden over the WHOLE graph (original behaviour).
# `entities` : run over the entity-only subgraph, then propagate each Chunk the
#              majority community of the entities it MENTIONS. Produces more
#              topic-coherent communities (recommended for large corpora).
COMMUNITY_SOURCE=full

CHUNKER_TYPE=recursive
CHUNKER_CHUNK_SIZE=1000
CHUNKER_CHUNK_OVERLAP=100

# --- Embeddings: SiliconFlow (硅基流动), OpenAI-compatible ---
# Get an API key at https://cloud.siliconflow.cn
# BAAI/bge-m3 outputs 1024 dims (same as the previous mxbai-embed-large).
EMBEDDINGS_TYPE=siliconflow
EMBEDDINGS_MODEL_NAME=BAAI/bge-m3
EMBEDDINGS_API_KEY=your_siliconflow_api_key_here
EMBEDDINGS_DEPLOYMENT=none
EMBEDDINGS_ENDPOINT=https://api.siliconflow.cn/v1

# --- Relation Extraction LLM: Zhipu AI (智谱 GLM), OpenAI-compatible ---
# Get an API key at https://open.bigmodel.cn
RE_MODEL_TYPE=zhipu
RE_MODEL_NAME=glm-4.7
RE_MODEL_TEMPERATURE=0.0
RE_API_KEY=your_zhipu_api_key_here
RE_MODEL_DEPLOYMENT=none
RE_MODEL_ENDPOINT=https://open.bigmodel.cn/api/coding/paas/v4/

# --- Q&A LLM: Zhipu AI (智谱 GLM) ---
QA_MODEL_TYPE=zhipu
QA_MODEL_NAME=glm-4.7
QA_MODEL_TEMPERATURE=0.0
QA_API_KEY=your_zhipu_api_key_here
QA_MODEL_DEPLOYMENT=none
QA_MODEL_ENDPOINT=https://open.bigmodel.cn/api/coding/paas/v4/
